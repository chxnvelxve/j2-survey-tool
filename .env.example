# --- App ---
APP_ENV=development
SECRET_KEY=changeme
# When ACCESS_MODE=shared_password, SECRET_KEY must be changed from changeme (session cookie signing).

# --- Database ---
POSTGRES_USER=j2
POSTGRES_PASSWORD=changeme
POSTGRES_DB=j2survey
DATABASE_URL=postgresql+psycopg://j2:changeme@db:5432/j2survey

# --- Storage (local default; Nextcloud WebDAV shell ready) ---
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/app/storage

# Nextcloud — required when STORAGE_BACKEND=nextcloud (no silent fallback to local).
# Live activation blocked on Josh (#12). Sample shape:
#   NEXTCLOUD_URL=https://nextcloud.example.com
#   → WebDAV: {URL}/remote.php/dav/files/{USERNAME}/{WEBDAV_ROOT}/{rel_path}
# NEXTCLOUD_URL=https://nextcloud.example.com
# NEXTCLOUD_USERNAME=survey-bot
# NEXTCLOUD_PASSWORD=app-password-from-nextcloud
# NEXTCLOUD_WEBDAV_ROOT=j2-survey

# --- Branding (kept OUT of engine code; re-skin per client here) ---
# 🟡 Phase 9 sample — swap real J2 logo/hex when Josh provides assets.
BRAND_COMPANY_NAME=J2 Communications
BRAND_LOGO_PATH=branding/j2_logo_placeholder.png
BRAND_PRIMARY_COLOR=#1F4E79

# --- Report template ---
DOCX_TEMPLATE_PATH=/app/templates_docx/survey_report.docx

# --- Deploy / access (Phase 7) ---
PUBLIC_HOSTNAME=survey.example.com
ACCESS_MODE=tailscale
# SHARED_ACCESS_PASSWORD=   # required when ACCESS_MODE=shared_password (MODE B shared-password gate)
# Also requires a non-default SECRET_KEY (not blank / changeme).
