# --- App ---
APP_ENV=development
SECRET_KEY=changeme

# --- Database ---
POSTGRES_USER=j2
POSTGRES_PASSWORD=changeme
POSTGRES_DB=j2survey
DATABASE_URL=postgresql+psycopg://j2:changeme@db:5432/j2survey

# --- Storage (local stub now; Nextcloud later) ---
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/app/storage

# Nextcloud — blocked on Josh (#12); STORAGE_BACKEND=nextcloud raises until configured.
# NEXTCLOUD_URL=
# NEXTCLOUD_USERNAME=
# NEXTCLOUD_PASSWORD=
# NEXTCLOUD_WEBDAV_ROOT=

# --- Branding (kept OUT of engine code; re-skin per client here) ---
# 🟡 Phase 9 sample — swap real J2 logo/hex when Josh provides assets.
BRAND_COMPANY_NAME=J2 Communications
BRAND_LOGO_PATH=branding/j2_logo_placeholder.png
BRAND_PRIMARY_COLOR=#1F4E79

# --- Report template ---
DOCX_TEMPLATE_PATH=/app/templates_docx/survey_report.docx

# --- Deploy / access (Phase 7) ---
PUBLIC_HOSTNAME=survey.example.com
ACCESS_MODE=tailscale
# SHARED_ACCESS_PASSWORD=   # required when ACCESS_MODE=shared_password (MODE B — not implemented in v1)
